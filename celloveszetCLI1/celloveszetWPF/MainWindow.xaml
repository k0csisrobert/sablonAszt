<Window x:Class="celloveszetWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:celloveszetWPF"
        mc:Ignorable="d"
        Title="celloveszetWPF" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="datagrid" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Grid.Column="1" Content="Név" HorizontalAlignment="Left" Margin="68,26,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Első lövés" HorizontalAlignment="Left" Margin="68,72,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Második lövés" HorizontalAlignment="Left" Margin="68,116,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Harmadik lövés" HorizontalAlignment="Left" Margin="68,161,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Negyedik lövés" HorizontalAlignment="Left" Margin="68,0,0,0" VerticalAlignment="Center"/>
        <TextBox x:Name="nev" Grid.Column="1" HorizontalAlignment="Left" Margin="225,30,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="L1" Grid.Column="1" HorizontalAlignment="Left" Margin="225,76,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="L2" Grid.Column="1" HorizontalAlignment="Left" Margin="225,120,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="L3" Grid.Column="1" HorizontalAlignment="Left" Margin="225,165,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="L4" Grid.Column="1" HorizontalAlignment="Left" Margin="225,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120"/>
        <Button Grid.Column="1" Content="Hozzáad" HorizontalAlignment="Left" Margin="265,257,0,0" VerticalAlignment="Top" Click="hozzaad" />
        <Button Grid.Column="1" Content="Mentés" HorizontalAlignment="Left" Margin="265,307,0,0" VerticalAlignment="Top" Click="mentes" />

    </Grid>
</Window>
