<Window x:Class="hegyekWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hegyekWPF"
        mc:Ignorable="d"
        Title="hegyekWPF" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="datagrid" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Grid.Column="1" Content="Név" HorizontalAlignment="Left" Margin="60,50,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Hegység" HorizontalAlignment="Left" Margin="60,94,0,0" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Magasság" HorizontalAlignment="Left" Margin="60,137,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="nev" Grid.Column="1" HorizontalAlignment="Left" Margin="207,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="hegyseg" Grid.Column="1" HorizontalAlignment="Left" Margin="207,98,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="magassag" Grid.Column="1" HorizontalAlignment="Left" Margin="207,141,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button Grid.Column="1" Content="Hozzáad" HorizontalAlignment="Left" Margin="247,0,0,0" VerticalAlignment="Center" Click="hozzaad"/>
        <Button Grid.Column="1" Content="Mentés" HorizontalAlignment="Left" Margin="250,250,0,0" VerticalAlignment="Top" Click="mentes"/>

    </Grid>
</Window>
